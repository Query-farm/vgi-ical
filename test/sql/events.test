# name: test/sql/events.test
# group: [vgi_ical]
#
# ical_events over committed .ics fixtures: row values, ORDER BY dtstart,
# UNNEST(attendees), all-day flag, and timezone (UTC) normalisation.

require-env VGI_ICAL_WORKER

# httpfs supplies DuckDB's HTTP client, which the vgi extension requires for the
# HTTP worker transport (http:// LOCATION); it is a harmless no-op for the
# subprocess and unix transports. CI's preprocess-require.awk rewrites this into
# an explicit `INSTALL httpfs FROM core; LOAD httpfs;`.
require httpfs

# NOTE: under haybarn-unittest `require vgi` SKIPS the file; load explicitly.
statement ok
LOAD vgi;

statement ok
ATTACH 'ical' AS ical (TYPE vgi, LOCATION '${VGI_ICAL_WORKER}');

# ---- rich feed: one VEVENT with all the trimmings ---------------------------

# dtstart is UTC-normalised (a TIMESTAMP WITH TIME ZONE rendered as +00).
query IIIII
SELECT summary, dtstart, dtend, all_day, rrule
FROM ical.ical_events('test/sql/data/team.ics')
ORDER BY dtstart;
----
Sprint Planning	2024-01-15 09:30:00+00	2024-01-15 10:30:00+00	false	FREQ=WEEKLY;BYDAY=MO

query IIII
SELECT uid, location, status, organizer
FROM ical.ical_events('test/sql/data/team.ics');
----
event-1@query.farm	Conference Room A	CONFIRMED	mailto:alice@query.farm

# attendees is a VARCHAR[] — UNNEST yields one row per attendee, in order.
query I
SELECT UNNEST(attendees) AS a
FROM ical.ical_events('test/sql/data/team.ics')
ORDER BY a;
----
mailto:bob@query.farm
mailto:carol@query.farm

query I
SELECT len(attendees) FROM ical.ical_events('test/sql/data/team.ics');
----
2

# categories is a VARCHAR[] — CATEGORIES split on commas; url + audit timestamps.
query I
SELECT array_to_string(categories, '|') FROM ical.ical_events('test/sql/data/team.ics');
----
Engineering|Planning

query III
SELECT url, created, last_modified
FROM ical.ical_events('test/sql/data/team.ics');
----
https://cal.query.farm/events/event-1	2024-01-01 08:00:00+00	2024-01-10 12:00:00+00

# ---- all-day event: DATE-valued DTSTART -> all_day = true -------------------

query III
SELECT summary, dtstart, all_day
FROM ical.ical_events('test/sql/data/holiday.ics');
----
Company Holiday	2024-07-04 00:00:00+00	true

# ---- zoned event: TZID + VTIMEZONE -> UTC ----------------------------------

# 09:00 America/New_York in January (EST, -05:00) == 14:00 UTC.
query II
SELECT summary, dtstart
FROM ical.ical_events('test/sql/data/zoned.ics');
----
NYC Standup	2024-01-15 14:00:00+00

# ---- garbage bytes: no rows, no crash --------------------------------------

query I
SELECT count(*) FROM ical.ical_events('test/sql/data/garbage.ics');
----
0

statement ok
DETACH ical;
